      "parameters": {
        "jsCode": "const results = [];\n\nfor (const item of $input.all()) {\n  let texto = item.json.text || item.json.response || item.json.output || \"\";\n  \n  // Remove markdown caso a AI envolva em ```json\n  texto = texto.replace(/```json\\s*/g, \"\").replace(/```/g, \"\").trim();\n  \n  let dados;\n  try {\n    dados = JSON.parse(texto);\n  } catch (e) {\n    dados = {\n      tipo: \"PARSE_FALHA\",\n      cnpj: \"\",\n      razao_social: \"\",\n      data_emissao: \"\",\n      data_validade: \"\",\n      valor: null,\n      ignorar: true,\n      erro: \"AI não retornou JSON válido\"\n    };\n  }\n\n  results.push({ json: dados });\n}\n\nreturn results;"
      },
