      "parameters": {
        "jsCode": "const results = [];\n\nfor (const item of $input.all()) {\n  let texto = \"\";\n  \n  try {\n    texto = item.json.candidates[0].content.parts[0].text || \"\";\n  } catch (e) {\n    texto = '{\"tipo\":\"PARSE_FALHA\",\"cnpj\":\"\",\"razao_social\":\"\",\"data_emissao\":\"\",\"data_validade\":\"\",\"valor\":null,\"ignorar\":true}';\n  }\n\n  texto = texto.replace(/```json\\s*/g, \"\").replace(/```/g, \"\").trim();\n\n  results.push({ json: { text: texto } });\n}\n\nreturn results;"
      },
