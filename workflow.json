    {
      "parameters": {
        "jsCode": "const results = [];\n\nfor (const item of $input.all()) {\n  const dados = item.json;\n  const hoje = new Date();\n  hoje.setHours(0, 0, 0, 0);\n\n  let status = \"SEM_VALIDADE\";\n  let diasRestantes = null;\n\n  if (dados.data_validade) {\n    const validade = new Date(dados.data_validade + \"T00:00:00\");\n    const diffMs = validade.getTime() - hoje.getTime();\n    diasRestantes = Math.ceil(diffMs / (1000 * 60 * 60 * 24));\n\n    if (diasRestantes < 0) {\n      status = \"VENCIDO\";\n    } else if (diasRestantes <= 30) {\n      status = \"VENCE_EM_BREVE\";\n    } else {\n      status = \"VALIDO\";\n    }\n  }\n\n  results.push({\n    json: {\n      cnpj: dados.cnpj || \"\",\n      razao_social: dados.razao_social || \"\",\n      tipo: dados.tipo || \"\",\n      data_emissao: dados.data_emissao || \"\",\n      data_validade: dados.data_validade || \"\",\n      valor: dados.valor,\n      status: status,\n      dias_restantes: diasRestantes,\n      data_verificacao: hoje.toISOString().split(\"T\")[0]\n    }\n  });\n}\n\nreturn results;"
      },
