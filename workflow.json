        "jsCode": "const results = [];\n\nfor (const item of $input.all()) {\n  const binaryKeys = Object.keys(item.binary || {});\n  \n  for (const key of binaryKeys) {\n    results.push({\n      json: {\n        remetente: item.json.from,\n        assunto: item.json.subject,\n        dataEmail: item.json.date,\n        nomeArquivo: item.binary[key].fileName,\n        tipoArquivo: item.binary[key].mimeType\n      },\n      binary: {\n        data: item.binary[key],\n        backup: item.binary[key]\n      }\n    });\n  }\n}\n\nreturn results;"
