      "parameters": {
        "jsCode": "const results = [];\nconst items = $input.all();\n\nfor (let i = 0; i < items.length; i++) {\n  const buffer = await this.helpers.getBinaryDataBuffer(i, 'backup');\n  const base64 = buffer.toString('base64');\n  \n  results.push({\n    json: {\n      base64: base64,\n      mimeType: items[i].binary?.backup?.mimeType || \"application/pdf\",\n      nomeArquivo: items[i].binary?.backup?.fileName || \"documento\"\n    }\n  });\n}\n\nreturn results;"
      },
